				"backgroundColorBottom": "#f4f7ff"
			}
		},
		{
			"path": "pages/indexApp/xkt/xkt",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/indexApp/rl-new/rl-new",
			"style": {
				"navigationBarTitleText": "私人小日历",
				"enablePullDownRefresh": false,
				"navigationBarBackgroundColor": "#fbeaf0",
				"backgroundColorTop": "#fbeaf0",
				"backgroundColorBottom": "#fbeaf0"
			}
		},
		{
			"path": "pages/indexApp/djs/djs",
			"style": {
				"navigationBarTitleText": "",
